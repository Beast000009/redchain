# ─── RedChain .gitignore ─────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/

# Environment variables (contains API keys!)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Reports (generated per-scan, don't commit)
reports/*.json
reports/*.md
reports/*.csv
reports/*.pdf
reports/*.txt

# Temp files from scans
/tmp/gobuster_*
/tmp/nikto_*
/tmp/redchain_wordlist.txt

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
