# ─── RedChain Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# All keys are optional — RedChain will skip integrations with missing keys.

# ── LLM Provider (choose one) ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider selection (gemini, openai, ollama)
LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash          # Override default model
# OLLAMA_BASE_URL=http://localhost:11434  # For Ollama
# OPENAI_BASE_URL=                       # For Azure/compatible APIs

# ── Security Tool APIs ───────────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here
VULNERS_API_KEY=your_vulners_api_key_here
NVD_API_KEY=your_nvd_api_key_here

# ── Threat Intelligence APIs ─────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
GREYNOISE_API_KEY=your_greynoise_api_key_here
